---
---
[
  {% for item in site.documents %}
  {
    "title": {{ item.title | default: item.slug | jsonify }},
    "url": {{ item.url | jsonify }},
    "content": {{ item.content | strip_html | normalize_whitespace | truncatewords: 300 | jsonify }},
    "excerpt": {{ item.excerpt | default: item.content | strip_html | normalize_whitespace | truncatewords: 50 | jsonify }},
    "category": {{ item.collection | default: "page" | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
  {% for page in site.pages %}
  {% if page.title and page.url != "/404.html" and page.url != "/search.json" %}
  ,{
    "title": {{ page.title | jsonify }},
    "url": {{ page.url | jsonify }},
    "content": {{ page.content | strip_html | normalize_whitespace | truncatewords: 300 | jsonify }},
    "excerpt": {{ page.content | strip_html | normalize_whitespace | truncatewords: 50 | jsonify }},
    "category": "page"
  }
  {% endif %}
  {% endfor %}
]
